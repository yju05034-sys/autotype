<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0a0a0a"
    android:padding="20dp">
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="💀 KiB_FANTER 💀"
        android:textColor="#ff0000"
        android:textSize="28sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="4dp" />
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="⚡ AUTO TYPE KEYBOARD ⚡"
        android:textColor="#cc0000"
        android:textSize="13sp"
        android:gravity="center"
        android:layout_marginBottom="20dp" />
    <EditText
        android:id="@+id/et_text"
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:background="#1a0000"
        android:textColor="#ff4444"
        android:hint="متن خودکار..."
        android:textColorHint="#660000"
        android:padding="12dp"
        android:gravity="top"
        android:inputType="textMultiLine"
        android:layout_marginBottom="10dp" />
    <Button
        android:id="@+id/btn_save"
        android:layout_width="match_parent"
        android:layout_height="46dp"
        android:text="💾 ذخیره"
        android:backgroundTint="#1a0000"
        android:textColor="#ff4444"
        android:layout_marginBottom="16dp" />
    <Button
        android:id="@+id/btn_start"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:text="💀 شروع 💀"
        android:backgroundTint="#8b0000"
        android:textColor="#ffffff"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />
    <Button
        android:id="@+id/btn_stop"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:text="⛔ توقف ⛔"
        android:backgroundTint="#330000"
        android:textColor="#ff4444"
        android:textSize="20sp"
        android:layout_marginBottom="20dp" />
    <Button
        android:id="@+id/btn_enable"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:text="⚙ فعال‌سازی کیبورد"
        android:backgroundTint="#111111"
        android:textColor="#888888"
        android:layout_marginBottom="6dp" />
    <Button
        android:id="@+id/btn_select"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:text="✅ انتخاب KiB_FANTER"
        android:backgroundTint="#111111"
        android:textColor="#888888" />
    <TextView
        android:id="@+id/tv_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="#ff0000"
        android:gravity="center"
        android:layout_marginTop="12dp"
        android:text="" />
</LinearLayout>
